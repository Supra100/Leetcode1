class Solution {
    public int maxProfit(int[] prices) {
        int n=prices.length;
        int minprice=prices[0];
        int maxprice=0;
        for(int i=0;i<n;i++){
            if(minprice>prices[i]){
                minprice=prices[i];
            }else{
                int profit=prices[i] - minprice;
                if(maxprice<profit){
                    maxprice=profit;
                }                
            }
        }
        return maxprice;
    }
}
